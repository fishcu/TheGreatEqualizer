<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <!-- Fit to Input -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fit_light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:text="@string/fit_to_input"
            android:textColor="?attr/colorOnSecondary"
            app:backgroundTint="?attr/colorSecondary" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#333333" />

        <!-- Shadows -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_shadows"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_shadows"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_shadows"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Highlights -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_highlights"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_highlights"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_highlights"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#333333" />

        <!-- Midtone Balance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_midtone_balance"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_midtone_balance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_midtone_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Midtone Contrast -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_midtone_contrast"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_midtone_contrast"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_midtone_contrast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#333333" />

        <!-- Lift (Blacks) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_blacks"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_blacks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="-0.20"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_blacks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Gain (Whites) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_whites"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_whites"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="-1.0"
                android:valueTo="0.2"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_whites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#333333" />

        <!-- Smoothing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_smoothing"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.thegreatequalizer.app.TickMarkSlider
                android:id="@+id/slider_light_smoothing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="#03DAC5"
                app:trackColorActive="#03DAC5"
                app:trackColorInactive="#444444" />

            <TextView
                android:id="@+id/value_light_smoothing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:minWidth="48dp"
                android:text="0.00"
                android:textColor="#BBBBBB"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
